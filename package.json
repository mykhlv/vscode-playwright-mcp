{
  "name": "vscode-playwright-mcp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "spike:1": "tsx spikes/01-launch-screenshot.ts",
    "spike:2": "tsx spikes/02-a11y-tree.ts",
    "spike:3": "tsx spikes/03-interaction-loop.ts",
    "spike:4": "tsx spikes/04-evaluate-vscode-api.ts",
    "spike:5": "tsx spikes/05-snapshot-tooltips.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "gifenc": "^1.0.3",
    "playwright-core": "^1.58.2",
    "pngjs": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.39.4",
    "eslint-plugin-vitest": "^0.5.4",
    "jiti": "^2.6.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
