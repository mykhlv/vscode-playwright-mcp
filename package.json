{
  "name": "vscode-playwright-mcp",
  "version": "0.1.0",
  "description": "Playwright for VS Code. MCP server that gives LLMs full mouse, keyboard, and visual control over VS Code via Playwright's Electron API.",
  "type": "module",
  "license": "MIT",
  "author": "vscode-playwright-mcp contributors",
  "keywords": [
    "mcp",
    "vscode",
    "playwright",
    "electron",
    "automation",
    "testing",
    "llm",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mykhlv/vscode-playwright-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mykhlv/vscode-playwright-mcp/issues"
  },
  "homepage": "https://github.com/mykhlv/vscode-playwright-mcp#readme",
  "files": [
    "dist"
  ],
  "bin": {
    "vscode-playwright-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/mcp": "0.0.68",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.39.4",
    "eslint-plugin-vitest": "^0.5.4",
    "jiti": "^2.6.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
